# =============================================================================
# LinkUp local development environment
# Sourced by docker-compose AND by the backend (via Spring's relaxed binding)
# =============================================================================

# =========================
# APPLICATION
# =========================
SERVER_PORT=8080
SPRING_PROFILES_ACTIVE=dev

# =========================
# DATABASE (POSTGRESQL)
# =========================
DB_NAME=linkup
DB_URL=jdbc:postgresql://localhost:5432/linkup
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DRIVER=org.postgresql.Driver

# =========================
# REDIS
# =========================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_TIMEOUT=2000

# =========================
# KEYCLOAK (IAM)
# =========================
# Realm "linkup" is auto-imported from infrastructure/keycloak/realms/ on first boot.
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin
KEYCLOAK_REALM=linkup
KEYCLOAK_ISSUER_URI=http://localhost:8081/realms/linkup

# Public SPA/mobile client (no secret — PKCE flow). Used by the frontend to obtain JWTs.
KEYCLOAK_CLIENT_ID=linkup-web

# =========================
# OBSERVABILITY
# =========================
LOG_LEVEL_ROOT=INFO
LOG_LEVEL_APP=DEBUG

# =========================
# DEV TOOLS
# =========================
SWAGGER_ENABLED=true
PGADMIN_EMAIL=admin@linkup.com
PGADMIN_PASSWORD=admin

# =========================
# BUSINESS CONFIG (LINKUP)
# =========================
BOOKING_MAX_ITEMS_PER_USER=5
ACTIVITY_DEFAULT_PAGE_SIZE=20
ACTIVITY_MAX_PAGE_SIZE=100

# =========================
# MAIL (MAILHOG — dev)
# =========================
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=

# OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318   # prod/staging only
# MANAGEMENT_OTLP_METRICS_EXPORT_ENABLED=true              # prod/staging only
# MANAGEMENT_OTLP_TRACING_EXPORT_ENABLED=true              # prod/staging only

# =========================
# EXTERNAL SERVICES (PHASE > MVP — placeholders, not wired yet)
# =========================
# PAYMENT_PROVIDER=CINETPAY
# CINETPAY_API_KEY=change-me
# CINETPAY_SITE_ID=change-me
